{
  "name": "heating-equipment-selection",
  "private": true,
  "description": "Корень репозитория: API в папке backend, UI в папке frontend.",
  "scripts": {
    "dev": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:full": "npx --yes concurrently -k -n api,ui -c blue,green \"npm run start --prefix backend\" \"npm run dev --prefix frontend\"",
    "start": "npm run start --prefix backend",
    "server": "npm run server --prefix backend",
    "lint": "npm run lint --prefix backend",
    "lint:frontend": "npm run lint --prefix frontend",
    "typecheck:shared": "npm run typecheck --prefix shared",
    "typecheck:backend": "npm run typecheck --prefix backend",
    "typecheck:frontend": "npm run typecheck --prefix frontend",
    "verify:type-bypass": "node scripts/verifyNoTypeBypass.mjs",
    "verify:shared": "npm run typecheck --prefix shared",
    "verify:frontend": "npm run verify --prefix frontend",
    "verify:backend": "npm run verify --prefix backend",
    "build:frontend": "npm run build --prefix frontend",
    "verify": "npm run verify:type-bypass && npm run verify:shared && npm run verify:backend && npm run verify:frontend",
    "seed": "npm run seed --prefix backend",
    "verify:seed-catalog": "npm run verify:seed-catalog --prefix backend"
  },
  "devDependencies": {
    "axios": "^1.18.1",
    "tsx": "^4.22.4"
  }
}
