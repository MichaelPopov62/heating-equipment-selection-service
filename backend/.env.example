PORT=3001

GEOCODE_USER_AGENT=heating-selection-service/1.0 (email@example.com)

METEOSTAT_YEARS=10
LOG_LEVEL=info

# MongoDB (см. utils/mongoConnectionConfig.js: normalizeMongoUri, getMongoConnectionConfigs, getMongoConnectionConfigOrNull)
MONGODB_URI=
MONGODB_URI_FALLBACK=
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_URL=
MONGODB_DB=
# Dev: пусто — localhost:5173. Prod: https://app.example.com (разные origin) или пусто (same-origin /api через nginx)
CORS_ORIGIN=
# Prod за reverse proxy: 1 или true (дефолт при NODE_ENV=production)
# TRUST_PROXY=1

# --- API проектов (production) ---
# JWT: JWKS (Clerk/Auth0) или HS256-секрет для staging
# AUTH_JWKS_URI=https://example.com/.well-known/jwks.json
# AUTH_JWT_SECRET=
# AUTH_ISSUER=
# AUTH_AUDIENCE=
# Dev: auth выключен по умолчанию; включить проверку JWT локально:
# PROJECTS_AUTH_ENABLED=true
# PROJECTS_DEV_OWNER_ID=dev-local
# RATE_LIMIT_DISABLED=true

# Rate limits (запросов / 15 мин на user или IP; dev-дефолт calc — 120, production — 20)
# RATE_LIMIT_CALC_PER_15M=120
# RATE_LIMIT_PROJECT_CALC_PER_15M=15
# RATE_LIMIT_PROJECTS_WRITE_PER_15M=60
# RATE_LIMIT_PROJECTS_READ_PER_15M=120
# RATE_LIMIT_PUBLIC_SHARE_PER_15M=120

# --- Серверный PDF сметы (Chromium) ---
# Docker/apt: PDF_BROWSER_EXECUTABLE=/usr/bin/chromium
# Локально: путь к Chrome/Chromium или пакет puppeteer (bundled Chrome)
# PDF_BROWSER_EXECUTABLE=
# PDF_RENDER_TIMEOUT_MS=30000
# PDF_MAX_CONCURRENT=2
# PDF_REQUIRE_BROWSER=1  # для CI: fail verify:project-pdf без браузера

# Квоты Mongo
# PROJECTS_MAX_PER_OWNER=200
# PROJECTS_MAX_CALCULATIONS_PER_PROJECT=100

# DNS для mongodb+srv: MONGODB_DISABLE_PUBLIC_DNS=1 | MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1

# Источники справочников: file | mongo | 
CATALOG_SOURCE=auto
WATER_NORMS_SOURCE=auto
APPLIANCES_SOURCE=auto
# После правок backend/data/appliances.json — cd backend && npm run seed (hydraulics schemaVersion 2)
RECOMMENDATIONS_SOURCE=auto
UFH_PRESETS_SOURCE=auto

# Опционально: CATALOG_FILE_PATH, SEED_CATALOG_PATH, REFERENCE_CACHE_TTL_MS
# REFERENCE_WARMUP_BLOCK_STARTUP=false  # true — await warmup до listen (readiness в prod/k8s)

# On-demand сброс in-memory bundle после seed (POST /api/v1/system/invalidate-reference-cache)
# SYSTEM_INTERNAL_TOKEN=          # секрет; заголовок X-System-Token
# API_BASE_URL=http://127.0.0.1:3001
# AUTO_INVALIDATE_CACHE=false   # true — seed дергает invalidate (также auto при NODE_ENV=production)
# MONGODB_AUTH_MECHANISM=SCRAM-SHA-256
# MONGODB_AUTH_SOURCE=admin
# SEED_DEBUG_MONGO=1
