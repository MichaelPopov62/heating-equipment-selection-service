{
  "extends": "../tsconfig.strict-base.json",
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "esnext",
    "lib": ["esnext"],
    "types": ["node"],
    "allowJs": true,
    "checkJs": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "maxNodeModuleJsDepth": 0
  },
  "include": [
    "src/**/*.js",
    "src/**/*.d.ts",
    "scripts/**/*.js",
    "scripts/**/*.ts",
    "../shared/**/*.js",
    "../shared/**/*.d.ts",
    "../shared/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
