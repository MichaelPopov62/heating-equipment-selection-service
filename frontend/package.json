{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty",
    "preview": "vite preview",
    "verify:survey-session": "node scripts/verifySurveySessionPipeline.mjs",
